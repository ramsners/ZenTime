# App
APP_PORT=8080

# Database (Docker: DB_HOST=db)
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=easytime
DB_USERNAME=easytime
DB_PASSWORD=easytime

# MariaDB container bootstrap (must match DB_* user/database)
MYSQL_ROOT_PASSWORD=rootsecret

# Migration source (host path; mounted in compose migrate profile)
# SQLITE_SOURCE_PATH=database/database.sqlite
